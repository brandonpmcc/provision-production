# ============================================
# ProVision Production App — Environment Variables
# Copy this file to .env.local for local dev,
# and set these in Vercel for production.
# ============================================

# Airtable Personal Access Token
# Create at: https://airtable.com/create/tokens
# Required scopes: data.records:read, data.records:write, schema.bases:read
# Required base access: ProVision (appHvFXShVSNjLCrG)
AIRTABLE_TOKEN=

# Airtable Base ID (ProVision)
AIRTABLE_BASE_ID=appHvFXShVSNjLCrG

# CompanyCam API Token
# Get from CompanyCam → Settings → Integrations → Personal Access Tokens
COMPANYCAM_TOKEN=

# NextAuth (Google sign-in)
# Get from Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# NextAuth secret — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# NextAuth URL (your deployed URL)
# Local dev: http://localhost:3000
# Production: https://production.provisionpaints.com (or your Vercel URL)
NEXTAUTH_URL=http://localhost:3000

# Email allowlist — only these accounts can sign in
# Comma-separated list of work emails
ALLOWED_EMAILS=brandon@provisionpaints.com,miriam@provisionpaints.com,jacob@provisionpaints.com,colin@provisionpaints.com,nico@provisionpaints.com,tyler@provisionpaints.com
